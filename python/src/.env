# Market Trend AI - Environment Configuration
# Local environment file

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Flask server port (default: 5001)
PORT=5001

# Debug mode (true/false)
DEBUG=false

# ============================================================================
# API KEYS
# ============================================================================

# CoinGecko API Key (optional for free tier, required for premium features)
COINGECKO_API_KEY=

# Hugging Face API Key (required for premium models)
HUGGINGFACE_API_KEY=

# Alpha Vantage API Key (required for stock, forex, commodities data)
ALPHA_VANTAGE_API_KEY=

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache duration in seconds (default: 300 = 5 minutes)
CACHE_DURATION=300

# Cache type: 'file' or 'redis'
CACHE_TYPE=file

# Redis configuration (if CACHE_TYPE=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# File cache directory
CACHE_DIR=.cache

# ============================================================================
# API RATE LIMITS
# ============================================================================

# Maximum number of retries for failed API requests
MAX_RETRIES=3

# Initial retry delay in seconds
RETRY_DELAY=1

# Maximum retry delay in seconds
MAX_RETRY_DELAY=60

# Request timeout in seconds
REQUEST_TIMEOUT=30

# CoinGecko API rate limit (calls per minute)
COINGECKO_RATE_LIMIT=10

# Alpha Vantage API rate limit (calls per minute)
ALPHA_VANTAGE_RATE_LIMIT=5

# Hugging Face API rate limit (calls per minute)
HUGGINGFACE_RATE_LIMIT=50

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty for console only)
LOG_FILE=logs/app.log

# Enable detailed API logging
LOG_API_REQUESTS=false

# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

# Default sentiment analysis model
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Default text generation model
TEXT_GENERATION_MODEL=gpt2

# Default conversational model
CONVERSATIONAL_MODEL=microsoft/DialoGPT-medium

# Maximum tokens for text generation
MAX_TOKENS=200

# Temperature for text generation (0.0 - 1.0)
GENERATION_TEMPERATURE=0.7

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application environment: development, production
APP_ENV=development

# Enable debug mode
DEBUG=false

# Enable verbose error messages
VERBOSE_ERRORS=true

# Data sources to use (comma-separated): coingecko,alphavantage
ACTIVE_DATA_SOURCES=coingecko,alphavantage

# Default cryptocurrency to fetch
DEFAULT_CRYPTO=bitcoin

# Default stock symbol
DEFAULT_STOCK=AAPL

# Default currency for market data
DEFAULT_CURRENCY=USD
