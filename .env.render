# =============================================================================
# Market Trend AI - Render Environment Variables
# =============================================================================
# Configure these in the Render Dashboard under "Environment" for each service
# =============================================================================

# -----------------------------------------------------------------------------
# PYTHON BACKEND SERVICE ENVIRONMENTS
# -----------------------------------------------------------------------------

# Python Service - Port (Render auto-sets this)
PORT=5000

# Flask environment
FLASK_ENV=production

# CoinGecko API - Get free key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Alpha Vantage API - Get free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Hugging Face API - Get key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# OpenAI API (optional)
OPENAI_API_KEY=

# Google AI (optional)
GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# NODE.JS SERVICE ENVIRONMENTS
# -----------------------------------------------------------------------------

# Node Service - Port (Render auto-sets this)
PORT=10000

# Application environment
NODE_ENV=production

# Session secret - generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_generate_random_string

# JWT secret - generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_random_string

# Python backend URL - will be: https://market-trend-ai-python.onrender.com
# Fill this in AFTER deploying the Python service
PYTHON_BACKEND_URL=

# Application URL - will be: https://market-trend-ai.onrender.com
APP_URL=https://market-trend-ai.onrender.com

# CORS origins - Update with your Render domains
CORS_ORIGIN=https://market-trend-ai.onrender.com

# Cache settings
CACHE_TYPE=memory
CACHE_DURATION=300

# Data sources
ACTIVE_DATA_SOURCES=coingecko,alphavantage
DEFAULT_CRYPTO=bitcoin
DEFAULT_STOCK=AAPL
DEFAULT_CURRENCY=USD

# AI Model settings
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
MAX_TOKENS=200
GENERATION_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
DEBUG=false
VERBOSE_ERRORS=false

# Security
TRUSTED_PROXIES=*
